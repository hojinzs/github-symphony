{
  "name": "@gh-symphony/control-plane",
  "version": "0.0.14",
  "private": true,
  "license": "MIT",
  "author": "hojinzs",
  "description": "Operator-facing HTTP control plane for GitHub Symphony",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "client/dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hojinzs/github-symphony.git",
    "directory": "packages/control-plane"
  },
  "homepage": "https://github.com/hojinzs/github-symphony#readme",
  "bugs": {
    "url": "https://github.com/hojinzs/github-symphony/issues"
  },
  "scripts": {
    "build": "pnpm build:client && pnpm build:server",
    "build:client": "vite build --config client/vite.config.ts",
    "build:storybook": "storybook build -c client/.storybook -o client/storybook-static",
    "build:server": "tsup src/index.ts --format esm --dts --clean",
    "dev:client": "vite --config client/vite.config.ts",
    "dev:server": "tsup src/index.ts --watch --format esm",
    "lint": "eslint src client/src client/.storybook client/vite.config.ts client/tailwind.config.ts --ext .ts,.tsx",
    "storybook": "storybook dev -p 6006 -c client/.storybook",
    "typecheck": "pnpm build:client >/dev/null && tsc -p tsconfig.typecheck.json && tsc -p client/tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@gh-symphony/core": "workspace:*",
    "@gh-symphony/dashboard": "workspace:*"
  },
  "devDependencies": {
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/themes": "^3.2.1",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-query": "^5.90.5",
    "@tanstack/router-plugin": "^1.132.6",
    "@tanstack/react-router": "^1.132.6",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.4",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.12.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "storybook": "^10.3.5",
    "tailwindcss": "^4.1.14",
    "tsup": "^8.5.1",
    "vite": "^7.1.12"
  }
}
