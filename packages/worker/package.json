{
  "name": "@gh-symphony/worker",
  "version": "0.0.14",
  "private": true,
  "license": "MIT",
  "author": "hojinzs",
  "description": "Symphony worker runtime for executing single issue runs",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hojinzs/github-symphony.git",
    "directory": "packages/worker"
  },
  "homepage": "https://github.com/hojinzs/github-symphony#readme",
  "bugs": {
    "url": "https://github.com/hojinzs/github-symphony/issues"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --watch src/index.ts",
    "lint": "eslint src --ext .ts",
    "start:codex": "node dist/local-runtime-launcher.js",
    "start": "node dist/index.js",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.typecheck.json"
  },
  "dependencies": {
    "@gh-symphony/core": "workspace:*",
    "@gh-symphony/extension-github-workflow": "workspace:*",
    "@gh-symphony/runtime-claude": "workspace:*",
    "@gh-symphony/runtime-codex": "workspace:*",
    "@gh-symphony/tracker-github": "workspace:*"
  }
}
