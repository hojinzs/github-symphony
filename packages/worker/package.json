{
  "name": "@github-symphony/worker",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --watch src/index.ts",
    "lint": "eslint src --ext .ts",
    "start:codex": "node dist/local-runtime-launcher.js",
    "start": "node dist/index.js",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@github-symphony/core": "workspace:*",
    "@github-symphony/extension-github-workflow": "workspace:*",
    "@github-symphony/runtime-codex": "workspace:*",
    "@github-symphony/tracker-github": "workspace:*"
  }
}
