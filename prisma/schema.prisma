generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GitHubAuthType {
  oauth
  pat
}

enum GitHubIntegrationStatus {
  pending
  ready
  degraded
}

enum SymphonyInstanceStatus {
  provisioning
  ready
  running
  degraded
  stopped
  failed
}

enum SymphonyRuntimeDriver {
  docker
  local
}

enum WorkspaceStatus {
  draft
  provisioning
  active
  failed
}

enum AgentCredentialProvider {
  openai
}

enum AgentCredentialStatus {
  pending
  ready
  degraded
  revoked
}

enum WorkspaceAgentCredentialSource {
  platform_default
  workspace_override
}

model GitHubCredential {
  id               String          @id @default(cuid())
  authType         GitHubAuthType
  githubUserId     String?
  githubLogin      String
  tokenFingerprint String          @unique
  scopes           String[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  workspaces       Workspace[]
}

model GitHubIntegration {
  id                     String                  @id @default(cuid())
  singletonKey           String                  @unique @default("system")
  status                 GitHubIntegrationStatus @default(pending)
  encryptedPatToken      String?
  patTokenFingerprint    String?
  patActorId             String?
  patActorLogin          String?
  patValidatedOwnerId    String?
  patValidatedOwnerLogin String?
  patValidatedOwnerType  String?
  patValidatedOwnerUrl   String?
  lastValidatedAt        DateTime?
  degradedReason         String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
}

model Workspace {
  id                    String                         @id @default(cuid())
  slug                  String                         @unique
  name                  String
  promptGuidelines      String?
  status                WorkspaceStatus                @default(draft)
  githubOwnerLogin      String
  githubProjectId       String?                        @unique
  githubProjectUrl      String?
  githubCredentialId    String?
  agentCredentialSource WorkspaceAgentCredentialSource @default(platform_default)
  agentCredentialId     String?
  createdAt             DateTime                       @default(now())
  updatedAt             DateTime                       @updatedAt
  githubCredential      GitHubCredential?              @relation(fields: [githubCredentialId], references: [id], onDelete: SetNull)
  agentCredential       AgentCredential?               @relation("WorkspaceAgentCredentialOverride", fields: [agentCredentialId], references: [id], onDelete: SetNull)
  repositories          WorkspaceRepository[]
  symphonyInstance      SymphonyInstance?
}

model WorkspaceRepository {
  id         String    @id @default(cuid())
  workspaceId String
  owner      String
  name       String
  cloneUrl   String
  createdAt  DateTime  @default(now())
  workspace  Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, owner, name])
}

model SymphonyInstance {
  id             String                 @id @default(cuid())
  workspaceId    String                 @unique
  runtimeDriver  SymphonyRuntimeDriver
  runtimeId      String                 @unique
  runtimeName    String                 @unique
  endpointHost   String                 @default("127.0.0.1")
  port           Int
  workflowPath   String
  runtimePath    String
  processId      Int?
  status         SymphonyInstanceStatus @default(provisioning)
  degradedReason String?
  lastHeartbeat  DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  workspace      Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model AgentCredential {
  id                String                  @id @default(cuid())
  label             String
  provider          AgentCredentialProvider @default(openai)
  encryptedSecret   String
  secretFingerprint String                  @unique
  status            AgentCredentialStatus   @default(pending)
  lastValidatedAt   DateTime?
  degradedReason    String?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  workspaces        Workspace[]             @relation("WorkspaceAgentCredentialOverride")
  defaultConfigs    PlatformAgentCredentialConfig[] @relation("PlatformDefaultAgentCredential")
}

model PlatformAgentCredentialConfig {
  singletonKey             String           @id @default("system")
  defaultAgentCredentialId String?          @unique
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt
  defaultAgentCredential   AgentCredential? @relation("PlatformDefaultAgentCredential", fields: [defaultAgentCredentialId], references: [id], onDelete: SetNull)
}
