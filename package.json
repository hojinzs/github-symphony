{
  "name": "github-symphony",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "dependencies": {
    "@prisma/client": "6.19.2"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter control-plane dev",
    "dev:control-plane": "pnpm --filter control-plane dev",
    "dev:worker": "pnpm --filter @github-symphony/worker dev",
    "lint": "pnpm -r lint",
    "prisma:db-push": "prisma db push",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "test": "pnpm -r test",
    "test:watch": "vitest",
    "typecheck": "pnpm -r --workspace-concurrency=1 typecheck",
    "format": "prettier --check .",
    "format:write": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^24.0.0",
    "eslint": "^9.22.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "prisma": "6.19.2",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1",
    "vitest": "^3.0.8"
  }
}
