# ============================================================
# GitHub Symphony - 로컬 개발 환경변수
# 사용법: cp .env.example .env
#
# 로컬 개발:
#   PostgreSQL 실행 후 pnpm dev:control-plane
# ============================================================

# --- 데이터베이스 ---
POSTGRES_DB=github_symphony
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/github_symphony

# --- Control Plane URL ---
# 외부(브라우저)에서 접근하는 주소 (운영자 OAuth 콜백 등록에 사용됨)
CONTROL_PLANE_BASE_URL=http://localhost:3000
# 로컬 워커 프로세스가 Control Plane에 접근하는 주소
CONTROL_PLANE_RUNTIME_URL=http://127.0.0.1:3000
SYMPHONY_RUNTIME_DRIVER=local

# --- 암호화 키 ---
# 머신 유저 PAT와 에이전트 자격증명 암호화에 사용 (32바이트 base64)
# 생성: openssl rand -base64 32
PLATFORM_SECRETS_KEY=

# --- 시스템 GitHub 부트스트랩 ---
# 주의: machine-user GitHub PAT를 .env에 넣지 않습니다.
# 첫 실행 후 /setup/github 화면에서 PAT와 Organization owner를 입력하면
# Control Plane이 검증 후 DB에 암호화해서 저장합니다.
# 즉, GITHUB_PAT / GITHUB_TOKEN 같은 환경변수는 필요하지 않습니다.

# --- 운영자 GitHub OAuth ---
# Control Plane 운영자 로그인에 사용하는 별도 GitHub OAuth App 설정
GITHUB_OPERATOR_CLIENT_ID=
GITHUB_OPERATOR_CLIENT_SECRET=
# 선택 사항: 쉼표로 구분된 허용 GitHub 로그인 목록. 비워두면 모든 GitHub 로그인을 허용
GITHUB_OPERATOR_ALLOWED_LOGINS=
# 선택 사항: 미설정 시 PLATFORM_SECRETS_KEY를 세션 서명에 재사용
OPERATOR_SESSION_SECRET=

# --- 워크스페이스 런타임 인증 ---
# Worker 컨테이너 ↔ Control Plane 간 인증 HMAC 시드 (32바이트 base64)
# 생성: openssl rand -base64 32
WORKSPACE_RUNTIME_AUTH_SECRET=

# --- Docker (선택: docker 드라이버에서만 필요) ---
DOCKER_SOCKET_PATH=/var/run/docker.sock
SYMPHONY_IMAGE=github-symphony-worker:local

# --- 앱 표시 이름 (선택) ---
NEXT_PUBLIC_APP_NAME=GitHub Symphony
